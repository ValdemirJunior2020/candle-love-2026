# Docker Compose configuration for Candle Love.
# Copy this file to .env before running Docker.

# PostgreSQL (kept private inside Docker; port 5432 is bound to localhost only)
POSTGRES_USER=candle_app
POSTGRES_PASSWORD=123456
POSTGRES_DB=candle_love

# API server
NODE_ENV=development
PORT=5000
SERVER_NAME=candle-love-api
SERVER_URL=http://localhost:5000
UPLOAD_DIR=/app/uploads
MAX_PROFILE_PHOTO_MB=8
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
DATABASE_SSL=false
JWT_SECRET=CHANGE_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_DOMAIN=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
LOG_LEVEL=info

# Payments (leave blank until configured)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
REVENUECAT_WEBHOOK_SECRET=
SPARK_PACK_50_PRODUCT_ID=candle_sparks_50
SPARK_PACK_140_PRODUCT_ID=candle_sparks_140
SPARK_PACK_320_PRODUCT_ID=candle_sparks_320

# Optional Cloudflare Tunnel for a permanent public HTTPS API URL.
# Create a named tunnel in Cloudflare Zero Trust, point it to http://server:5000,
# paste its token here, then run: docker compose --profile public up -d
CLOUDFLARE_TUNNEL_TOKEN=
