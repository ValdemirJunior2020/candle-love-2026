# Public Expo values only. Never place private secrets in EXPO_PUBLIC_* variables.
EXPO_PUBLIC_APP_NAME=Candle Love
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_API_URL=http://localhost:5000
EXPO_PUBLIC_API_TIMEOUT=15000
EXPO_PUBLIC_WEBSITE_URL=https://example.com
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://example.com/privacy
EXPO_PUBLIC_TERMS_URL=https://example.com/terms
EXPO_PUBLIC_SUPPORT_URL=https://example.com/support
EXPO_PUBLIC_SUPPORT_EMAIL=support@example.com
EXPO_PUBLIC_EXPO_OWNER=YOUR_EXPO_OWNER
EXPO_PUBLIC_EAS_PROJECT_ID=YOUR_EAS_PROJECT_ID
EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER=com.candlelove.app
EXPO_PUBLIC_ANDROID_PACKAGE=com.candlelove.app
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_YOUR_PUBLIC_REVENUECAT_KEY
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_YOUR_PUBLIC_REVENUECAT_KEY
EXPO_PUBLIC_ENABLE_PAYMENTS=false
