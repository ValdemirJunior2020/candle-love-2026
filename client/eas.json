{
  "cli": { "version": ">= 16.18.0", "appVersionSource": "remote" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": { "EXPO_PUBLIC_APP_ENV": "development" },
      "ios": { "simulator": false },
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": { "EXPO_PUBLIC_APP_ENV": "preview", "EXPO_PUBLIC_DEMO_MODE": "false" },
      "ios": { "resourceClass": "m-medium" },
      "android": { "buildType": "apk" }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": { "EXPO_PUBLIC_APP_ENV": "production", "EXPO_PUBLIC_DEMO_MODE": "false" },
      "ios": { "resourceClass": "m-medium" }
    }
  },
  "submit": {
    "production": {
      "ios": { "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID" },
      "android": { "serviceAccountKeyPath": "./google-play-service-account.json", "track": "internal" }
    }
  }
}
