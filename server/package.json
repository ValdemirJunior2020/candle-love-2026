{
  "name": "@candle-love/server",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src/services/moderation.test.ts",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:migrate:prod": "node dist/migrate.js",
    "db:seed:prod": "node dist/seed.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "fastify-raw-body": "^5.0.0",
    "jose": "^6.1.0",
    "postgres": "^3.4.7",
    "socket.io": "^4.8.1",
    "stripe": "^19.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.0",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.0.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
