# Render supplies PORT automatically.
NODE_ENV=production
SERVER_NAME=candle-love-api
DATABASE_URL=SET_BY_RENDER_BLUEPRINT
DATABASE_SSL=true
UPLOAD_DIR=/opt/render/project/src/uploads
MAX_PROFILE_PHOTO_MB=8

# Replace candle-love-web with the exact Netlify site name.
# The wildcard permits Netlify deploy-preview and branch-deploy hostnames for this site only.
CORS_ALLOWED_ORIGINS=https://candle-love-web.netlify.app,https://*--candle-love-web.netlify.app

JWT_SECRET=GENERATED_BY_RENDER
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
LOG_LEVEL=info
