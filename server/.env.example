# Use this file only when running the API directly with npm instead of Docker.
NODE_ENV=development
PORT=5000
SERVER_NAME=candle-love-api
SERVER_URL=http://localhost:5000
UPLOAD_DIR=./uploads
MAX_PROFILE_PHOTO_MB=8
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
DATABASE_URL=postgresql://candle_app:YOUR_DATABASE_PASSWORD@localhost:5432/candle_love
DATABASE_SSL=false
JWT_SECRET=REPLACE_WITH_A_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_DOMAIN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
REVENUECAT_WEBHOOK_SECRET=
SPARK_PACK_50_PRODUCT_ID=candle_sparks_50
SPARK_PACK_140_PRODUCT_ID=candle_sparks_140
SPARK_PACK_320_PRODUCT_ID=candle_sparks_320
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
LOG_LEVEL=debug
